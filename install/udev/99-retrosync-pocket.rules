# RetroSync — fire a one-shot sync when the Analogue Pocket presents
# itself as a USB Mass-Storage device.
#
# Installed to /etc/udev/rules.d/99-retrosync-pocket.rules and reloaded
# by `udevadm control --reload && udevadm trigger`.
#
# Vendor:product 04d8:ca19 is the openFPGA Analogue Pocket — the
# Microchip Technology USB controller it uses. Confirm yours with
# `lsusb | grep -i analogue` if the rule doesn't fire.
#
# Filesystem: SD cards >32 GB ship as exfat by default; smaller ones
# are usually vfat. Match either so the rule fires regardless of how
# the user formatted theirs.
#
# We match SUBSYSTEM=="block" and ID_FS_TYPE so we only fire on the
# mountable partition, not the whole-disk device.

ACTION=="add", SUBSYSTEM=="block", ENV{ID_FS_TYPE}=="vfat|exfat", \
  ENV{ID_VENDOR_ID}=="04d8", ENV{ID_MODEL_ID}=="ca19", \
  ENV{SYSTEMD_WANTS}+="retrosync-pocket-sync@%k.service", \
  TAG+="systemd"

# Fallback for kernels/udev versions that don't populate ID_VENDOR_ID at
# the partition level. Walks up the device tree to match the parent USB
# device's IDs.
ACTION=="add", SUBSYSTEM=="block", ENV{ID_FS_TYPE}=="vfat|exfat", \
  ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="ca19", \
  ENV{SYSTEMD_WANTS}+="retrosync-pocket-sync@%k.service", \
  TAG+="systemd"
