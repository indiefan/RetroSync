[Unit]
Description=RetroSync save backup daemon
Documentation=https://github.com/indiefan/RetroSync
After=network-online.target sni.service
Wants=network-online.target sni.service

[Service]
Type=simple
User=retrosync
Group=retrosync
Environment=RETROSYNC_CONFIG=/etc/retrosync/config.yaml
# rclone's default config search path is ~/.config/rclone/rclone.conf, which
# is hidden by ProtectHome=true even though we ReadWritePaths it back in.
# Setting RCLONE_CONFIG explicitly bypasses the path search.
Environment=RCLONE_CONFIG=/home/retrosync/.config/rclone/rclone.conf
ExecStart=/opt/retrosync/.venv/bin/retrosyncd --config ${RETROSYNC_CONFIG}
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/lib/retrosync /home/retrosync/.config/rclone

[Install]
WantedBy=multi-user.target
